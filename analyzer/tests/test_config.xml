<?xml version="1.0" encoding="UTF-8"?>
<КонфигурацияМЭ Версия="4.0">
    <Объекты>

        <Объект ID="net_1" Тип="Сеть">
            <Адрес>192.168.0.0</Адрес>
            <Маска>255.255.255.0</Маска>
        </Объект>

        <Объект ID="net_2" Тип="Сеть">
            <Адрес>10.0.0.0</Адрес>
            <Маска>255.0.0.0</Маска>
        </Объект>

        <Объект ID="host_1" Тип="Хост">
            <Адрес>192.168.0.10</Адрес>
        </Объект>

        <Объект ID="srv_http" Тип="Сервис">
            <Порт>80</Порт>
            <Протокол>TCP</Протокол>
        </Объект>

        <Объект ID="srv_https" Тип="Сервис">
            <Порт>443</Порт>
            <Протокол>TCP</Протокол>
        </Объект>

    </Объекты>

    <ПравилаФильтрации>

        <Правило ID="1" Номер="1" Действие="Разрешить" Приоритет="10" Описание="Разрешить HTTP к host_1 из локальной сети">
            <Источник>net_1</Источник>
            <Назначение>host_1</Назначение>
            <Сервис>srv_http</Сервис>
        </Правило>

        <Правило ID="2" Номер="2" Действие="Разрешить" Приоритет="20" Описание="Резервное правило для HTTP доступа">
            <Источник>192.168.0.0/24</Источник>
            <Назначение>192.168.0.10</Назначение>
            <Сервис>80/tcp</Сервис>
        </Правило>

        <Правило ID="3" Номер="3" Действие="Запретить" Приоритет="5" Описание="Запрет HTTP в определенных условиях">
            <Источник>net_1</Источник>
            <Назначение>host_1</Назначение>
            <Сервис>srv_http</Сервис>
            <Время>00:00-06:00</Время>
        </Правило>

        <Правило ID="4" Номер="4" Действие="Разрешить" Приоритет="15" Описание="Разрешить HTTPS доступ">
            <Источник>net_1</Источник>
            <Назначение>host_1</Назначение>
            <Сервис>srv_https</Сервис>
        </Правило>

    </ПравилаФильтрации>

    <NAT>

        <ПравилоNAT ID="n1" Тип="SNAT" Описание="Статический NAT для host_1">
            <Источник>192.168.0.10</Источник>
            <Назначение>any</Назначение>
            <Преобразование>
                <Тип>статический</Тип>
                <ПереводИсхАдреса>203.0.113.10</ПереводИсхАдреса>
            </Преобразование>
        </ПравилоNAT>

        <ПравилоNAT ID="n2" Тип="PAT" Описание="PAT для всей сети">
            <Источник>192.168.0.0/24</Источник>
            <Назначение>any</Назначение>
            <Преобразование>
                <Тип>динамический</Тип>
                <ПереводИсхАдреса>203.0.113.5</ПереводИсхАдреса>
            </Преобразование>
        </ПравилоNAT>

        <ПравилоNAT ID="n3" Тип="SNAT" Описание="Альтернативный NAT для host_1">
            <Источник>192.168.0.10</Источник>
            <Назначение>any</Назначение>
            <Преобразование>
                <Тип>статический</Тип>
                <ПереводИсхАдреса>198.51.100.20</ПереводИсхАдреса>
            </Преобразование>
        </ПравилоNAT>

    </NAT>

    <Настройки>
        <ПолитикаПоУмолчанию>Запретить</ПолитикаПоУмолчанию>
        <Логирование>включено</Логирование>
        <УровеньЛогирования>нормальный</УровеньЛогирования>
    </Настройки>

</КонфигурацияМЭ>